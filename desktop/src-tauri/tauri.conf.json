{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "S.I.P.A.",
  "version": "0.1.0",
  "identifier": "com.sipa.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      { "label": "main", "title": "S.I.P.A.", "width": 480, "height": 680 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
