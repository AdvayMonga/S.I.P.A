# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# Claude API key — https://console.anthropic.com. Required.
ANTHROPIC_API_KEY=

# Absolute path to your Obsidian vault. The vault is its own local git repo,
# OUTSIDE this code repo (VISION.md §6). Required.
# e.g. /Users/advaymonga/Documents/vault
VAULT_PATH=

# Tavily web-search API key — https://tavily.com (free tier, no card). Optional:
# the web-search server is only spawned when this is set.
TAVILY_API_KEY=
