# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.

# Claude API key — https://console.anthropic.com. Required.
ANTHROPIC_API_KEY=

# Absolute path to your Obsidian vault. The vault is its own local git repo,
# OUTSIDE this code repo (VISION.md §6). Required.
# e.g. /Users/advaymonga/Documents/vault
VAULT_PATH=

# Tavily web-search API key — https://tavily.com (free tier, no card). Optional:
# the web-search server is only spawned when this is set.
TAVILY_API_KEY=

# Optional capabilities (all OFF unless set):
# FS_READ_ROOTS — os.pathsep-separated dirs the bot may READ (and see images in). Empty = no access.
FS_READ_ROOTS=
# EXEC_ROOT — working dir for shell execution. Empty = no shell. Approval-gated; never runs unattended.
EXEC_ROOT=
# APPROVAL_MODE — "ask" (prompt before risky/irreversible tools) or "trust" (run without asking).
APPROVAL_MODE=ask
